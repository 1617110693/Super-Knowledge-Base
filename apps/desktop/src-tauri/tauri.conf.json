{
  "$schema": "https://raw.githubusercontent.com/nicknisi/tauri-apps-tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Local Knowledge Base",
  "version": "0.1.0",
  "identifier": "com.local-knowledge-base.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "title": "Local Knowledge Base",
    "windows": [
      {
        "title": "Local Knowledge Base",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "python-backend",
          "cmd": "uv",
          "args": true
        }
      ]
    }
  }
}
