{
  "name": "local-knowledge-base",
  "version": "0.1.0",
  "private": true,
  "description": "Local Agent Knowledge Base — desktop app with MCP server integration",
  "workspaces": [
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm --workspace=desktop run dev",
    "tauri": "npm --workspace=desktop run tauri",
    "build": "npm --workspace=desktop run build",
    "python-backend": "uv run --directory services/python-backend knowledge-backend",
    "mcp-server": "uv run --directory apps/mcp-server local-kb-mcp"
  },
  "engines": {
    "node": ">=18"
  }
}
